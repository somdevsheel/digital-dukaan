NODE_ENV=development
PORT=4001
REDIS_URL="redis://localhost:6379"
# MUST match apps/api's JWT_ACCESS_SECRET byte-for-byte — see README "Auth".
JWT_ACCESS_SECRET="replace-with-a-strong-secret-in-.env"

# Optional — defaults to "info". One of pino's levels (trace/debug/info/warn/error/fatal).
# LOG_LEVEL=info
