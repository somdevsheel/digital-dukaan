# Copy to .env for local development. Never commit a real .env — see Architecture §17.

NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://marketplace:marketplace_dev_only@localhost:5432/marketplace?schema=public"
REDIS_URL="redis://localhost:6379"
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="dev_only_master_key"

# S3-compatible object storage — MinIO locally, R2/S3 in staging/prod (Architecture ADR-011)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_PUBLIC_BASE_URL=""
STORAGE_ACCESS_KEY_ID="marketplace"
STORAGE_SECRET_ACCESS_KEY="marketplace_dev_only"
STORAGE_BUCKET="marketplace-dev"

JWT_ACCESS_SECRET="replace-with-a-strong-secret-in-.env"
JWT_REFRESH_SECRET="replace-with-a-different-strong-secret-in-.env"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# 32 random bytes, base64-encoded — e.g. `openssl rand -base64 32`. Encrypts bank account
# numbers and other Architecture §17 high-sensitivity fields. Rotating this key requires
# re-encrypting existing rows — treat it like any other production secret.
FIELD_ENCRYPTION_KEY=""

GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# "mock" skips the real Razorpay API (useful with no live credentials on hand, e.g. a
# fresh local clone); set to "razorpay" once real keys below are filled in.
PAYMENT_PROVIDER="razorpay"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

SMS_PROVIDER="msg91"
SMS_API_KEY=""

RESEND_API_KEY=""

GOOGLE_MAPS_API_KEY=""
