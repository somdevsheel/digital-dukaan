    "@nestjs/event-emitter": "^2.1.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.0",
    "passport": "^0.7.0",
