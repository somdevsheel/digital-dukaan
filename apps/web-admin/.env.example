# Server-only — never exposed to the client. next.config.js rewrites /api/v1/* to this
# origin, so the browser always calls same-origin paths (no CORS/cross-site-cookie
# complexity for the httpOnly refresh-token cookie). See lib/api-client.ts. Matches the
# same pattern as apps/web-merchant — the original NEXT_PUBLIC_API_URL scaffold value
# here would have broken the httpOnly refresh cookie across origins.
API_ORIGIN="http://localhost:4000"

NEXT_PUBLIC_REALTIME_URL="http://localhost:4001"
